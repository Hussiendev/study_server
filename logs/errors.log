ffer"}},"_writableState":{"bufferedIndex":0,"corked":0,"highWaterMark":16384,"length":0,"pendingcb":0,"writelen":0},"allowHalfOpen":false,"alpnProtocol":false,"authorizationError":null,"authorized":true,"connecting":false,"encrypted":true,"parser":null,"secureConnecting":false,"servername":"api.deepseek.com","ssl":{"_parent":{"onconnection":null,"reading":true},"_parentWrap":null,"_secureContext":{"context":{}},"reading":true},"timeout":5000},"complete":true,"httpVersion":"1.1","httpVersionMajor":1,"httpVersionMinor":1,"method":null,"rawHeaders":["Content-Type","application/json","Content-Length","111","Connection","keep-alive","Date","Wed, 11 Mar 2026 17:12:36 GMT","Server","elb","vary","origin, access-control-request-method, access-control-request-headers","access-control-allow-credentials","true","x-ds-trace-id","2d9311c130427cdf7a4124ddfbfeb642","Strict-Transport-Security","max-age=31536000; includeSubDomains; preload","X-Content-Type-Options","nosniff","X-Cache","Error from cloudfront","Via","1.1 baaa01540e8048678da317f40119ee06.cloudfront.net (CloudFront)","X-Amz-Cf-Pop","MRS52-P4","X-Amz-Cf-Id","Gdt1_3MO6Votgkey2xwpu9jZN63Prr_-Bvxl8JX6PGk1-aDRoPbX0A=="],"rawTrailers":[],"redirects":[],"req":"[Circular]","responseUrl":"https://api.deepseek.com/v1/chat/completions","socket":null,"statusCode":402,"statusMessage":"Payment Required","upgrade":false,"url":""},"reusedSocket":false,"sendDate":false,"shouldKeepAlive":true,"strictContentLength":false,"timeoutCb":null,"upgradeOrConnect":false,"useChunkedEncodingByDefault":true,"writable":true},"response":{"config":{"adapter":["xhr","http","fetch"],"allowAbsoluteUrls":true,"data":"{\"model\":\"deepseek-chat\",\"messages\":[{\"role\":\"system\",\"content\":\"You are a helpful assistant that summarizes documents. \\n              Return a JSON object with exactly this structure:\\n              {\\n                \\\"brief\\\": \\\"string (2-3 sentences)\\\",\\n                \\\"mainPoints\\\": [\\\"string\\\", \\\"string\\\", ...] (3-5 bullet points),\\n                \\\"keyPhrases\\\": [\\\"string\\\", \\\"string\\\", ...] (5-10 key terms)\\n              }\"},{\"role\":\"user\",\"content\":\"Please summarize the following document.\\n\\nProvide a brief overview, 3-5 main points, and 5-10 key phrases.\\n\\nDocument:\\nlang \\twhich is always imported automatically\\nThis class has some methods that every Java class inherits\\n◦ \\tFor example, the \\tequals \\tand \\ttoString \\tmethods\\nEvery class inherits these methods from some ancestor class\\n◦ \\tEither \\tthe class \\tObject \\titself, \\tor \\ta \\tclass that itself inherited these \\tmethods\\n(ultimately) from the class \\tObject\\nHowever, \\tthese \\tinherited \\tmethods \\tshould \\tbe \\toverridden \\twith \\tdefinitions \\tmore\\nappropriate to a given class\\nCHAPTER 4 - INHERITANCE \\t47\\nPart 3 •Programming with Inheritance\\n• \\tThe Class \\tObject\\n• \\tStatic Members\\n• \\tComposition Relationship\\nCHAPTER 4 - INHERITANCE \\t48\\nDr. Abed EL Safadi\\nInherited Static Variables in Child Classes\\nA derived class inherits static variables (and methods) from its parent class\\nThe question is: does each child class has its own copy of the static variable?\\nAnswer: \\tNo\\nCHAPTER 4 - INHERITANCE \\t49\\nDr. Abed EL Safadi\\nInherited Static Variables in Child Classes\\nCHAPTER 4 - INHERITANCE \\t50\\npublic class Person {\\npublic static int x;\\n}\\npublic class Student extends Person {\\n}\\npublic static void main (){\\nStudent.x = 30;\\nSystem.out.println(Person.x);\\nSystem.out.println(Student.x);\\n}\\npublic static void main (){\\nPerson.x = 20;\\nSystem.out.println(Person.x);\\nSystem.out.println(Student.x);\\n}\\npublic static void main (){\\nPerson.x = 10;\\nSystem.out.println(Person.x);\\nSystem.out.println(Student.x);\\n}\\n10\\n10\\n20\\n20\\n30\\n30\\nDr. Abed EL Safadi\\nStatic variables in a base class are inherited by any derived classes as long as they're are\\nnot hidden by another static variable with the same identifier\\n• \\tThe static variable in the child class hides the static variable of the parent class\\n• \\tThe variable of the base class does not become inaccessible: child can still access it\\nby fully qualifying with the name of parent class\\nCHAPTER 4 - INHERITANCE \\t51\\nHiding Static Variables in Child Classes\\nDr. Abed EL Safadi\\nCHAPTER 4 - INHERITANCE \\t52\\npublic class Person {\\npublic static int x;\\n}\\npublic class Student extends Person {\\npublic static int x;\\n} public static void main (){\\nStudent.x = 30;\\nSystem.out.println(Person.x);\\nSystem.out.println(Student.x);\\n}\\npublic static void main (){\\nPerson.x = 20;\\nSystem.out.println(Person.x);\\nSystem.out.println(Student.x);\\n}\\npublic static void main (){\\nPerson.x = 10;\\nSystem.out.println(Person.x);\\nSystem.out.println(Student.x);\\n}\\n10\\n0\\n20\\n0\\n0\\n30\\nHiding Static Variables in Child Classes\\nDr. Abed EL Safadi\\nHiding Static Methods\\nA subclass cannot override static methods and final methods defined in the superclass\\n• \\tYou can’t use the \\t@Override \\ttag\\nA subclass can hide a static method in the superclass by declaring a static method in the\\nsubclass with the same signature as the static method in the superclass\\nHowever, this static method that hides the superclass static method cannot access the\\nparent method using the \\tsuper \\tobject\\n• \\tChild can still access it by fully qualifying with the name of parent class\\nCHAPTER 4 - INHERITANCE \\t53\\nDr. Abed EL Safadi\\nHiding Static Methods\\nCHAPTER 4 - INHERITANCE \\t54\\npublic class Person {\\npublic static void testStaticMethod(){\\nSystem.out.println(\\\"Static method in Person\\\");\\n}\\n}\\npublic class Student extends Person {\\n@Override\\npublic static void testStaticMethod(){\\nSystem.out.println(\\\"Static method in Student\\\");\\n}\\n}\\npublic static void main (){\\nPerson.testStaticMethod();\\nStudent.testStaticMethod();\\n}\\nPart 3 •Programming with Inheritance\\n• \\tThe Class \\tObject\\n• \\tStatic Members\\n• \\tComposition Relationship\\nCHAPTER 4 - INHERITANCE \\t55\\nDr. Abed EL Safadi\\n\\\"Is a\\\" Versus \\\"Has a\\\"\\nA derived class demonstrates an \\t\\\"is a\\\" \\trelationship between it and its base class\\n• \\tForming an \\\"is a\\\" relationship is one way to make a more complex class out of a\\nsimpler class\\nAnother way to make a more complex class out of a simpler class is through a \\t\\\"has a\\\"\\nrelationship\\n• \\tThis type of relationship, called \\tcomposition, occurs when a class contains an\\ninstance variable of a class type\\nAn \\tIS-A \\trelationship is inheritance\\nHAS-A \\trelationship is composition\\nCHAPTER 4 - INHERITANCE \\t56\\nDr. Abed EL Safadi\\nComposition Relation\\nThe instance variables in a class can be simple data types like \\tint \\tand \\tdouble, but they\\ncan also be class types\\nThe composition relation describes the relationship between classes when an object of\\none class is an instance variable within another class\\nCHAPTER 4 - INHERITANCE \\t57\\nDr. Abed EL Safadi\\nComposition between the classes \\tPerson \\tand\\nDate\\nCHAPTER 4 - INHERITANCE \\t58\\npublic class Person {\\nprivate String fullName;\\nprivate String gender;\\nprivate int dayOfBirth;\\nprivate String monthOfBirth;\\nprivate int yearOfBirth;\\n…………..\\n}\\npublic class Date {\\nprivate int day;\\nprivate String month;\\nprivate int year;\\n…………..\\n}\\nDr. Abed EL Safadi\\nComposition between the classes \\tPerson \\tand\\nDate\\nCHAPTER 4 - INHERITANCE \\t59\\npublic class Person {\\nprivate String fullName;\\nprivate String gender;\\nprivate Date dateOfBirth;\\n…………..\\n}\\npublic class Date {\\nprivate int day;\\nprivate String month;\\nprivate int year;\\n…………..\\n}\\nDr. Abed EL Safadi\\nHow to access an object in a class in Java\\nTo access an object in a class we go another level deeper with dot notation\\nCHAPTER 4 - INHERITANCE \\t60\"}],\"temperatu